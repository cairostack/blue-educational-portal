# ──────────────────────────────────────────────────────────────────────────────
# Blue Educational Portal — Environment Variables
# Copy this file to .env.local and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# Strapi API base URL (server-only — NOT prefixed with NEXT_PUBLIC_)
# This is the primary variable name used by the app.
STRAPI_API_URL=https://admin-blue-educational.com/api

# Legacy alias — either STRAPI_API_URL or STRAPI_BASE_URL is accepted.
# STRAPI_BASE_URL=https://admin-blue-educational.com/api

# Strapi API token for authenticated requests (read-only token).
# Required if your Strapi "courses" collection is not publicly readable.
#
# How to generate a token:
#   1. Log in to your Strapi admin at https://admin-blue-educational.com/admin
#   2. Go to Settings → API Tokens → Create new API token
#   3. Set type to "Read-only" (or "Custom" with find/findOne on courses)
#   4. Copy the token here.
#
# How to configure public access (no token needed):
#   1. Go to Settings → Roles → Public
#   2. Under "Courses", enable "find" and "findOne"
#   3. Save — no STRAPI_API_TOKEN required.
#
STRAPI_API_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# Vercel deployment: add both vars as Environment Variables in the Vercel
# project settings (Settings → Environment Variables).
# ──────────────────────────────────────────────────────────────────────────────
